[Unit]
Description=PiWatchdog web UI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@PI_WATCHDOG_USER@
WorkingDirectory=@PI_WATCHDOG_INSTALL_DIR@
Environment=PI_WATCHDOG_PORT=@PI_WATCHDOG_PORT@
Environment=PI_WATCHDOG_LOG_PATH=@PI_WATCHDOG_LOG_PATH@
ExecStart=/usr/bin/python3 @PI_WATCHDOG_INSTALL_DIR@/pi_watchdog_ui.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
